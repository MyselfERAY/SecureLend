{
  "name": "securelend-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "clean": "turbo run clean",
    "type-check": "turbo run type-check"
  },
  "devDependencies": {
    "@turbo/gen": "^1.12.4",
    "@types/node": "^20.11.24",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "turbo": "^1.12.4",
    "typescript": "^5.3.3"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "resolutions": {
    "@types/react": "^18.2.45",
    "url-parse": "^1.5.10",
    "whatwg-url": "^14.0.0"
  },
  "pnpm": {
    "overrides": {
      "url-parse": "^1.5.10",
      "whatwg-url": "^14.0.0"
    }
  },
  "workspaces": [
    "apps/*",
    "packages/*"
