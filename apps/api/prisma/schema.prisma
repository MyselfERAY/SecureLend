generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Application {
  id              String            @id @default(uuid()) @db.Uuid
  tcknHash        String            @map("tckn_hash") @db.VarChar(128)
  tcknMasked      String            @map("tckn_masked") @db.VarChar(13)
  status          ApplicationStatus @default(PENDING)
  creditLimit     Decimal?          @map("credit_limit") @db.Decimal(12, 2)
  interestRate    Decimal?          @map("interest_rate") @db.Decimal(5, 2)
  rejectionReason String?           @map("rejection_reason") @db.VarChar(500)
  kkbScore        Int?              @map("kkb_score")
  kpsVerified     Boolean           @default(false) @map("kps_verified")
  ipAddress       String?           @map("ip_address") @db.VarChar(45)
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  userId          String?           @map("user_id") @db.Uuid
  user            User?             @relation(fields: [userId], references: [id])
  contracts       Contract[]

  @@index([tcknHash], map: "idx_application_tckn_hash")
  @@index([status], map: "idx_application_status")
  @@index([userId], map: "idx_application_user")
  @@index([createdAt], map: "idx_application_created_at")
  @@map("applications")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  action     String   @db.VarChar(100)
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   String?  @map("entity_id") @db.Uuid
  tcknMasked String?  @map("tckn_masked") @db.VarChar(13)
  metadata   Json?
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  createdAt  DateTime @default(now()) @map("created_at")
  userId     String?  @map("user_id") @db.Uuid

  @@index([entityType, entityId], map: "idx_audit_entity")
  @@index([userId], map: "idx_audit_user")
  @@index([createdAt], map: "idx_audit_created_at")
  @@map("audit_logs")
}

model User {
  id                String              @id @default(uuid()) @db.Uuid
  tcknHash          String              @unique @map("tckn_hash") @db.VarChar(128)
  tcknMasked        String              @map("tckn_masked") @db.VarChar(13)
  tcknEncrypted     String?             @map("tckn_encrypted") @db.VarChar(256)
  fullName          String              @map("full_name") @db.VarChar(200)
  phone             String              @db.VarChar(20)
  phoneVerified     Boolean             @default(false) @map("phone_verified")
  phoneTcknVerified Boolean             @default(false) @map("phone_tckn_verified")
  email             String?             @db.VarChar(255)
  pushToken         String?             @map("push_token") @db.VarChar(200)
  dateOfBirth       DateTime?           @map("date_of_birth") @db.Date
  address           String?             @db.VarChar(500)
  roles             UserRole[]          @default([])
  kycStatus         KycStatus           @default(PENDING) @map("kyc_status")
  kpsVerified       Boolean             @default(false) @map("kps_verified")
  nviVerified       Boolean             @default(false) @map("nvi_verified")
  nviVerifiedAt     DateTime?           @map("nvi_verified_at") @db.Timestamptz()
  onboardingCompleted Boolean            @default(false) @map("onboarding_completed")
  referralCode      String?             @unique @map("referral_code") @db.VarChar(10)
  isActive          Boolean             @default(true) @map("is_active")
  lastLoginAt       DateTime?           @map("last_login_at")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  applications      Application[]
  bankAccounts      BankAccount[]
  consents          Consent[]
  notifications     Notification[]
  signatures        ContractSignature[]
  landlordContracts Contract[]          @relation("ContractLandlord")
  tenantContracts   Contract[]          @relation("ContractTenant")
  kmhApplications   KmhApplication[]
  otpCodes          OtpCode[]
  ownedProperties      Property[]              @relation("PropertyOwner")
  refreshTokens        RefreshToken[]
  chatParticipations   ChatRoomParticipant[]
  chatMessages         ChatMessage[]
  userPromos           UserPromo[]           @relation("UserPromos")
  referredPromos       UserPromo[]           @relation("ReferredPromos")

  @@index([tcknHash], map: "idx_user_tckn_hash")
  @@index([phone], map: "idx_user_phone")
  @@index([kycStatus], map: "idx_user_kyc_status")
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.VarChar(128)
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  ipAddress String?   @map("ip_address") @db.VarChar(45)
  userAgent String?   @map("user_agent") @db.VarChar(500)
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash], map: "idx_refresh_token_hash")
  @@index([userId], map: "idx_refresh_token_user")
  @@index([expiresAt], map: "idx_refresh_token_expires")
  @@map("refresh_tokens")
}

model OtpCode {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String?   @map("user_id") @db.Uuid
  phone       String    @db.VarChar(20)
  code        String    @db.VarChar(6)
  purpose     String    @db.VarChar(50)
  attempts    Int       @default(0)
  maxAttempts Int       @default(3) @map("max_attempts")
  expiresAt   DateTime  @map("expires_at")
  verifiedAt  DateTime? @map("verified_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phone, purpose], map: "idx_otp_phone_purpose")
  @@index([expiresAt], map: "idx_otp_expires")
  @@map("otp_codes")
}

model KmhApplication {
  id                  String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String               @map("user_id") @db.Uuid
  employmentStatus    EmploymentStatus     @map("employment_status")
  monthlyIncome       Decimal              @map("monthly_income") @db.Decimal(12, 2)
  employerName        String?              @map("employer_name") @db.VarChar(200)
  residentialAddress  String               @map("residential_address") @db.VarChar(500)
  estimatedRent       Decimal              @map("estimated_rent") @db.Decimal(12, 2)
  status              KmhApplicationStatus @default(PENDING)
  approvedLimit       Decimal?             @map("approved_limit") @db.Decimal(12, 2)
  rejectionReason     String?              @map("rejection_reason") @db.VarChar(500)
  bankReferenceNo     String?              @map("bank_reference_no") @db.VarChar(50)
  onboardingCompleted Boolean              @default(false) @map("onboarding_completed")
  creditScore         Int?                 @map("credit_score")
  debtToIncomeRatio   Decimal?             @map("debt_to_income_ratio") @db.Decimal(5, 2)
  interestRate        Decimal?             @map("interest_rate") @db.Decimal(5, 2)
  monthlyInstallment  Decimal?             @map("monthly_installment") @db.Decimal(12, 2)
  offerAccepted       Boolean              @default(false) @map("offer_accepted")
  offerAcceptedAt     DateTime?            @map("offer_accepted_at")
  kycStatus           String               @default("NOT_STARTED") @map("kyc_status") @db.VarChar(20)
  kycIdVerified       Boolean              @default(false) @map("kyc_id_verified")
  kycSelfieVerified   Boolean              @default(false) @map("kyc_selfie_verified")
  kycVideoCompleted   Boolean              @default(false) @map("kyc_video_completed")
  kycAgreementsSigned Boolean              @default(false) @map("kyc_agreements_signed")
  existingCustomer    Boolean              @default(false) @map("existing_customer")
  evaluationDetails   Json?                @map("evaluation_details")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @default(now()) @updatedAt @map("updated_at")
  bankAccount         BankAccount?
  user                User                 @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId], map: "idx_kmh_app_user")
  @@index([status], map: "idx_kmh_app_status")
  @@map("kmh_applications")
}

model Property {
  id            String         @id @default(uuid()) @db.Uuid
  ownerId       String         @map("owner_id") @db.Uuid
  title         String         @db.VarChar(200)
  addressLine1  String         @map("address_line_1") @db.VarChar(300)
  addressLine2  String?        @map("address_line_2") @db.VarChar(300)
  city          String         @db.VarChar(100)
  district      String         @db.VarChar(100)
  neighborhood  String?        @db.VarChar(200)
  street        String?        @db.VarChar(300)
  postalCode    String?        @map("postal_code") @db.VarChar(10)
  uavtCode      String?        @map("uavt_code") @db.VarChar(10)
  uavtVerifiedAt DateTime?     @map("uavt_verified_at") @db.Timestamptz()
  propertyType  String         @map("property_type") @db.VarChar(50)
  roomCount     String?        @map("room_count") @db.VarChar(10)
  areaM2        Decimal?       @map("area_m2") @db.Decimal(8, 2)
  floor         Int?
  totalFloors   Int?           @map("total_floors")
  monthlyRent   Decimal        @map("monthly_rent") @db.Decimal(12, 2)
  depositAmount Decimal?       @map("deposit_amount") @db.Decimal(12, 2)
  currency      String         @default("TRY") @db.VarChar(3)
  description   String?
  status        PropertyStatus @default(ACTIVE)
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  contracts     Contract[]
  owner         User           @relation("PropertyOwner", fields: [ownerId], references: [id])

  @@index([ownerId], map: "idx_property_owner")
  @@index([city, district], map: "idx_property_location")
  @@index([status], map: "idx_property_status")
  @@index([monthlyRent], map: "idx_property_rent")
  @@map("properties")
}

model Contract {
  id                String              @id @default(uuid()) @db.Uuid
  propertyId        String              @map("property_id") @db.Uuid
  tenantId          String              @map("tenant_id") @db.Uuid
  landlordId        String              @map("landlord_id") @db.Uuid
  applicationId     String?             @map("application_id") @db.Uuid
  status            ContractStatus      @default(DRAFT)
  monthlyRent       Decimal             @map("monthly_rent") @db.Decimal(12, 2)
  depositAmount     Decimal?            @map("deposit_amount") @db.Decimal(12, 2)
  currency          String              @default("TRY") @db.VarChar(3)
  startDate         DateTime            @map("start_date") @db.Date
  endDate           DateTime            @map("end_date") @db.Date
  paymentDayOfMonth Int                 @default(1) @map("payment_day_of_month")
  terms             String?
  specialClauses    String?             @map("special_clauses")
  terminatedAt      DateTime?           @map("terminated_at")
  terminationReason String?             @map("termination_reason") @db.VarChar(500)
  rentIncreaseType   RentIncreaseType   @default(TUFE) @map("rent_increase_type")
  rentIncreaseRate   Decimal?           @map("rent_increase_rate") @db.Decimal(5, 2)
  furnitureIncluded  Boolean            @default(false) @map("furniture_included")
  petsAllowed        Boolean            @default(false) @map("pets_allowed")
  sublettingAllowed  Boolean            @default(false) @map("subletting_allowed")
  noticePeriodDays   Int                @default(30) @map("notice_period_days")
  documentPhotoUrl   String?            @map("document_photo_url") @db.VarChar(500)
  documentPhotoKey   String?            @map("document_photo_key") @db.VarChar(200)
  uavtCode           String?            @map("uavt_code") @db.VarChar(20)
  bankActivationRef  String?            @map("bank_activation_ref") @db.VarChar(100)
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  landlordIban      String?             @map("landlord_iban") @db.VarChar(26)
  bankAccounts      BankAccount[]
  commissions       Commission[]
  signatures        ContractSignature[]
  application       Application?        @relation(fields: [applicationId], references: [id])
  landlord          User                @relation("ContractLandlord", fields: [landlordId], references: [id])
  property          Property            @relation(fields: [propertyId], references: [id])
  tenant            User                @relation("ContractTenant", fields: [tenantId], references: [id])
  paymentOrders     PaymentOrder[]
  payments          PaymentSchedule[]
  chatRooms         ChatRoom[]
  userPromos        UserPromo[]

  @@index([propertyId], map: "idx_contract_property")
  @@index([tenantId], map: "idx_contract_tenant")
  @@index([landlordId], map: "idx_contract_landlord")
  @@index([status], map: "idx_contract_status")
  @@index([startDate, endDate], map: "idx_contract_dates")
  @@map("contracts")
}

model ContractSignature {
  id         String   @id @default(uuid()) @db.Uuid
  contractId String   @map("contract_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  role       UserRole
  signedAt   DateTime @default(now()) @map("signed_at")
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.VarChar(500)
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])

  @@unique([contractId, userId], name: "uq_contract_signature_user")
  @@index([contractId], map: "idx_signature_contract")
  @@index([userId], map: "idx_signature_user")
  @@map("contract_signatures")
}

model PaymentSchedule {
  id          String           @id @default(uuid()) @db.Uuid
  contractId  String           @map("contract_id") @db.Uuid
  dueDate     DateTime         @map("due_date") @db.Date
  amount      Decimal          @db.Decimal(12, 2)
  currency    String           @default("TRY") @db.VarChar(3)
  periodLabel String           @map("period_label") @db.VarChar(50)
  status      PaymentStatus    @default(PENDING)
  paidAt      DateTime?        @map("paid_at")
  paidAmount  Decimal?         @map("paid_amount") @db.Decimal(12, 2)
  failReason  String?          @map("fail_reason") @db.VarChar(500)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  transaction BankTransaction?
  commission  Commission?
  contract    Contract         @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId], map: "idx_payment_schedule_contract")
  @@index([dueDate], map: "idx_payment_schedule_due_date")
  @@index([status], map: "idx_payment_schedule_status")
  @@map("payment_schedules")
}

model BankAccount {
  id                   String            @id @default(uuid()) @db.Uuid
  userId               String            @map("user_id") @db.Uuid
  accountNumber        String            @unique @map("account_number") @db.VarChar(26)
  accountType          BankAccountType   @map("account_type")
  status               BankAccountStatus @default(PENDING_OPENING)
  balance              Decimal           @default(0) @db.Decimal(14, 2)
  currency             String            @default("TRY") @db.VarChar(3)
  creditLimit          Decimal?          @map("credit_limit") @db.Decimal(12, 2)
  interestRate         Decimal?          @map("interest_rate") @db.Decimal(5, 2)
  openedAt             DateTime?         @map("opened_at")
  closedAt             DateTime?         @map("closed_at")
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")
  contractId           String?           @map("contract_id") @db.Uuid
  kmhApplicationId     String?           @unique @map("kmh_application_id") @db.Uuid
  contract             Contract?         @relation(fields: [contractId], references: [id])
  kmhApplication       KmhApplication?   @relation(fields: [kmhApplicationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user                 User              @relation(fields: [userId], references: [id])
  outgoingTransactions BankTransaction[] @relation("TransactionFrom")
  incomingTransactions BankTransaction[] @relation("TransactionTo")
  paymentOrders        PaymentOrder[]

  @@index([userId], map: "idx_bank_account_user")
  @@index([contractId], map: "idx_bank_account_contract")
  @@index([accountNumber], map: "idx_bank_account_number")
  @@index([status], map: "idx_bank_account_status")
  @@map("bank_accounts")
}

model BankTransaction {
  id                String           @id @default(uuid()) @db.Uuid
  fromAccountId     String?          @map("from_account_id") @db.Uuid
  toAccountId       String?          @map("to_account_id") @db.Uuid
  paymentScheduleId String?          @unique @map("payment_schedule_id") @db.Uuid
  amount            Decimal          @db.Decimal(12, 2)
  currency          String           @default("TRY") @db.VarChar(3)
  description       String?          @db.VarChar(500)
  referenceNo       String           @unique @map("reference_no") @db.VarChar(36)
  status            String           @db.VarChar(20)
  processedAt       DateTime?        @map("processed_at")
  createdAt         DateTime         @default(now()) @map("created_at")
  fromAccount       BankAccount?     @relation("TransactionFrom", fields: [fromAccountId], references: [id])
  paymentSchedule   PaymentSchedule? @relation(fields: [paymentScheduleId], references: [id])
  toAccount         BankAccount?     @relation("TransactionTo", fields: [toAccountId], references: [id])

  @@index([fromAccountId], map: "idx_transaction_from")
  @@index([toAccountId], map: "idx_transaction_to")
  @@index([referenceNo], map: "idx_transaction_reference")
  @@index([createdAt], map: "idx_transaction_created")
  @@map("bank_transactions")
}

model PaymentOrder {
  id                String             @id @default(uuid()) @db.Uuid
  contractId        String             @map("contract_id") @db.Uuid
  fromAccountId     String             @map("from_account_id") @db.Uuid
  toIban            String             @map("to_iban") @db.VarChar(26)
  amount            Decimal            @db.Decimal(12, 2)
  currency          String             @default("TRY") @db.VarChar(3)
  dayOfMonth        Int                @map("day_of_month")
  status            PaymentOrderStatus @default(ACTIVE)
  nextExecutionDate DateTime           @map("next_execution_date") @db.Date
  lastExecutedAt    DateTime?          @map("last_executed_at")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  contract          Contract           @relation(fields: [contractId], references: [id])
  fromAccount       BankAccount        @relation(fields: [fromAccountId], references: [id])

  @@index([contractId], map: "idx_payment_order_contract")
  @@index([fromAccountId], map: "idx_payment_order_account")
  @@index([status, nextExecutionDate], map: "idx_payment_order_next_exec")
  @@map("payment_orders")
}

model Commission {
  id                String          @id @default(uuid()) @db.Uuid
  paymentScheduleId String          @unique @map("payment_schedule_id") @db.Uuid
  contractId        String          @map("contract_id") @db.Uuid
  totalAmount       Decimal         @map("total_amount") @db.Decimal(12, 2)
  commissionRate    Decimal         @map("commission_rate") @db.Decimal(5, 4)
  commissionAmount  Decimal         @map("commission_amount") @db.Decimal(12, 2)
  landlordAmount    Decimal         @map("landlord_amount") @db.Decimal(12, 2)
  currency          String          @default("TRY") @db.VarChar(3)
  createdAt         DateTime        @default(now()) @map("created_at")
  contract          Contract        @relation(fields: [contractId], references: [id])
  paymentSchedule   PaymentSchedule @relation(fields: [paymentScheduleId], references: [id])

  @@index([contractId], map: "idx_commission_contract")
  @@index([createdAt], map: "idx_commission_created")
  @@map("commissions")
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("application_status")
}

enum UserRole {
  TENANT
  LANDLORD
  ADMIN
  SERVICE

  @@map("user_role")
}

enum KycStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REJECTED

  @@map("kyc_status")
}

enum RentIncreaseType {
  TUFE
  FIXED_RATE
  NONE

  @@map("rent_increase_type")
}

enum ContractStatus {
  DRAFT
  PENDING_SIGNATURES
  PENDING_ACTIVATION
  ACTIVE
  TERMINATED
  EXPIRED

  @@map("contract_status")
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  OVERDUE

  @@map("payment_status")
}

enum PaymentOrderStatus {
  ACTIVE
  PAUSED
  CANCELLED
  COMPLETED

  @@map("payment_order_status")
}

enum BankAccountType {
  KMH
  STANDARD

  @@map("bank_account_type")
}

enum BankAccountStatus {
  PENDING_OPENING
  ACTIVE
  FROZEN
  CLOSED

  @@map("bank_account_status")
}

enum PropertyStatus {
  ACTIVE
  RENTED
  INACTIVE

  @@map("property_status")
}

enum EmploymentStatus {
  EMPLOYED
  SELF_EMPLOYED
  RETIRED
  STUDENT
  UNEMPLOYED

  @@map("employment_status")
}

enum KmhApplicationStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("kmh_application_status")
}

enum ConsentType {
  KVKK_AYDINLATMA
  KVKK_ACIK_RIZA
  KVKK_ACIK_RIZA_KMH
  TERMS_OF_SERVICE

  @@map("consent_type")
}

model Consent {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String      @map("user_id") @db.Uuid
  type       ConsentType
  version    String      @db.VarChar(10)
  accepted   Boolean     @default(true)
  ipAddress  String?     @map("ip_address") @db.VarChar(45)
  userAgent  String?     @map("user_agent") @db.VarChar(500)
  acceptedAt DateTime    @default(now()) @map("accepted_at") @db.Timestamptz()
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type], map: "idx_consent_user_type")
  @@map("consents")
}

enum NotificationType {
  KMH_APPROVED
  KMH_REJECTED
  KMH_ONBOARDING_COMPLETE
  CONTRACT_CREATED
  CONTRACT_SIGNED
  CONTRACT_ACTIVATED
  CONTRACT_TERMINATED
  PAYMENT_DUE
  PAYMENT_OVERDUE
  PAYMENT_COMPLETED
  CHAT_MESSAGE
  SYSTEM

  @@map("notification_type")
}

model Notification {
  id         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String           @map("user_id") @db.Uuid
  type       NotificationType
  title      String           @db.VarChar(200)
  body       String           @db.VarChar(1000)
  entityType String?          @map("entity_type") @db.VarChar(50)
  entityId   String?          @map("entity_id") @db.Uuid
  isRead     Boolean          @default(false) @map("is_read")
  readAt     DateTime?        @map("read_at") @db.Timestamptz()
  createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamptz()
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_notification_user")
  @@index([userId, isRead], map: "idx_notification_user_read")
  @@index([createdAt], map: "idx_notification_created")
  @@map("notifications")
}

// ─── Articles / Rehber ─────────────────────────────────────────

enum ArticleStatus {
  DRAFT
  PUBLISHED

  @@map("article_status")
}

enum ArticleAudience {
  TENANT
  LANDLORD
  BOTH

  @@map("article_audience")
}

model Article {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String          @db.VarChar(300)
  slug        String          @unique @db.VarChar(300)
  summary     String          @db.VarChar(500)
  content     String
  category    String          @db.VarChar(100)
  audience    ArticleAudience @default(BOTH)
  status      ArticleStatus   @default(DRAFT)
  publishedAt DateTime?       @map("published_at") @db.Timestamptz()
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([status, publishedAt], map: "idx_article_status_published")
  @@index([slug], map: "idx_article_slug")
  @@index([audience], map: "idx_article_audience")
  @@map("articles")
}

// ─── Dev Suggestions ──────────────────────────────────────────

enum SuggestionStatus {
  PENDING
  IN_PROGRESS
  DONE
  REJECTED

  @@map("suggestion_status")
}

enum SuggestionPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL

  @@map("suggestion_priority")
}

model DevSuggestion {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String             @db.VarChar(300)
  description String
  priority    SuggestionPriority @default(MEDIUM)
  status      SuggestionStatus   @default(PENDING)
  agentNotes  String?            @map("agent_notes")
  prLink      String?            @map("pr_link") @db.VarChar(500)
  createdAt   DateTime           @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  poItems     PoItem[]

  @@index([status], map: "idx_dev_suggestion_status")
  @@index([priority], map: "idx_dev_suggestion_priority")
  @@map("dev_suggestions")
}

// ─── Agent Runs ───────────────────────────────────────────────

enum AgentType {
  PO
  MARKETING
  DEV
  HEALTH
  ARTICLE
  ARCHITECT

  @@map("agent_type")
}

enum AgentRunStatus {
  RUNNING
  COMPLETED
  FAILED

  @@map("agent_run_status")
}

model AgentRun {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentType       AgentType      @map("agent_type")
  status          AgentRunStatus @default(RUNNING)
  startedAt       DateTime       @default(now()) @map("started_at") @db.Timestamptz()
  completedAt     DateTime?      @map("completed_at") @db.Timestamptz()
  tokenUsage      Int?           @map("token_usage")
  errorMessage    String?        @map("error_message")
  summary         String?
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz()
  poReports       PoReport[]
  marketingReports MarketingReport[]

  @@index([agentType], map: "idx_agent_run_type")
  @@index([status], map: "idx_agent_run_status")
  @@index([startedAt], map: "idx_agent_run_started")
  @@map("agent_runs")
}

// ─── PO Agent ─────────────────────────────────────────────────

enum PoItemCategory {
  UX_IMPROVEMENT
  COMPETITOR_ANALYSIS
  REGULATION_COMPLIANCE
  FEATURE_SUGGESTION
  BUG_REPORT
  METRIC_SUMMARY

  @@map("po_item_category")
}

enum PoItemStatus {
  ACTIVE
  MOVED_TO_DEV
  DISMISSED

  @@map("po_item_status")
}

model PoReport {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reportDate      DateTime  @unique @map("report_date") @db.Date
  summary         String
  metricsSnapshot Json?     @map("metrics_snapshot")
  agentRunId      String?   @map("agent_run_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  agentRun        AgentRun? @relation(fields: [agentRunId], references: [id], onDelete: SetNull)
  items           PoItem[]

  @@index([agentRunId], map: "idx_po_report_agent_run")
  @@map("po_reports")
}

model PoItem {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  poReportId      String?           @map("po_report_id") @db.Uuid
  category        PoItemCategory
  title           String            @db.VarChar(300)
  description     String
  priority        SuggestionPriority @default(MEDIUM)
  status          PoItemStatus      @default(ACTIVE)
  isDevTask       Boolean           @default(false) @map("is_dev_task")
  devSuggestionId String?           @map("dev_suggestion_id") @db.Uuid
  createdByAdmin  Boolean           @default(false) @map("created_by_admin")
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  poReport        PoReport?         @relation(fields: [poReportId], references: [id], onDelete: SetNull)
  devSuggestion   DevSuggestion?    @relation(fields: [devSuggestionId], references: [id], onDelete: SetNull)

  @@index([poReportId], map: "idx_po_item_report")
  @@index([category], map: "idx_po_item_category")
  @@index([status], map: "idx_po_item_status")
  @@index([devSuggestionId], map: "idx_po_item_dev_suggestion")
  @@map("po_items")
}

// ─── Marketing Agent ──────────────────────────────────────────

enum MarketingReportType {
  DAILY_STRATEGY
  MARKET_ANALYSIS
  RESEARCH
  BUSINESS_DEVELOPMENT

  @@map("marketing_report_type")
}

enum MarketingTaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
  CANCELLED

  @@map("marketing_task_status")
}

enum ResearchRequestStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED

  @@map("research_request_status")
}

model MarketingReport {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type        MarketingReportType
  title       String              @db.VarChar(300)
  content     String
  reportDate  DateTime            @map("report_date") @db.Date
  agentRunId  String?             @map("agent_run_id") @db.Uuid
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  agentRun    AgentRun?           @relation(fields: [agentRunId], references: [id], onDelete: SetNull)
  tasks       MarketingTask[]
  researchRequests ResearchRequest[]

  @@index([type], map: "idx_marketing_report_type")
  @@index([reportDate], map: "idx_marketing_report_date")
  @@index([agentRunId], map: "idx_marketing_report_agent_run")
  @@map("marketing_reports")
}

model MarketingTask {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  marketingReportId String?             @map("marketing_report_id") @db.Uuid
  source            String              @default("MARKETING") @db.VarChar(50)
  title             String              @db.VarChar(300)
  description       String
  responsible       String?             @db.VarChar(200)
  targetDate        DateTime?           @map("target_date") @db.Date
  status            MarketingTaskStatus @default(TODO)
  completedAt       DateTime?           @map("completed_at") @db.Timestamptz()
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  marketingReport   MarketingReport?    @relation(fields: [marketingReportId], references: [id], onDelete: SetNull)

  @@index([marketingReportId], map: "idx_marketing_task_report")
  @@index([status], map: "idx_marketing_task_status")
  @@index([targetDate], map: "idx_marketing_task_target_date")
  @@index([responsible], map: "idx_marketing_task_responsible")
  @@map("marketing_tasks")
}

model ResearchRequest {
  id              String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  topic           String                @db.VarChar(500)
  details         String?
  status          ResearchRequestStatus @default(PENDING)
  resultReportId  String?               @map("result_report_id") @db.Uuid
  requestedAt     DateTime              @default(now()) @map("requested_at") @db.Timestamptz()
  completedAt     DateTime?             @map("completed_at") @db.Timestamptz()
  resultReport    MarketingReport?      @relation(fields: [resultReportId], references: [id], onDelete: SetNull)

  @@index([status], map: "idx_research_request_status")
  @@map("research_requests")
}

// ─── Chat System ───────────────────────────────────────────────

enum ChatRoomType {
  CONTRACT
  SUPPORT

  @@map("chat_room_type")
}

model ChatRoom {
  id           String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type         ChatRoomType
  contractId   String?            @map("contract_id") @db.Uuid
  title        String?            @db.VarChar(200)
  isActive     Boolean            @default(true) @map("is_active")
  createdAt    DateTime           @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  contract     Contract?          @relation(fields: [contractId], references: [id])
  participants ChatRoomParticipant[]
  messages     ChatMessage[]

  @@index([contractId], map: "idx_chat_room_contract")
  @@index([type], map: "idx_chat_room_type")
  @@map("chat_rooms")
}

model ChatRoomParticipant {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chatRoomId String   @map("chat_room_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  joinedAt   DateTime @default(now()) @map("joined_at") @db.Timestamptz()
  chatRoom   ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])

  @@unique([chatRoomId, userId], name: "uq_chat_participant")
  @@index([userId], map: "idx_chat_participant_user")
  @@map("chat_room_participants")
}

model ChatMessage {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chatRoomId String   @map("chat_room_id") @db.Uuid
  senderId   String   @map("sender_id") @db.Uuid
  content    String   @db.VarChar(2000)
  isRead     Boolean  @default(false) @map("is_read")
  readAt     DateTime? @map("read_at") @db.Timestamptz()
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()
  chatRoom   ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  sender     User     @relation(fields: [senderId], references: [id])

  @@index([chatRoomId, createdAt], map: "idx_chat_message_room_date")
  @@index([senderId], map: "idx_chat_message_sender")
  @@index([chatRoomId, isRead], map: "idx_chat_message_unread")
  @@map("chat_messages")
}

// ─── PROMO SYSTEM ───────────────────────────
enum PromoType {
  FIRST_MONTHS_FREE      // Ilk X ay komisyonsuz
  RENEWAL_DISCOUNT       // 2. yil yenileme indirimi
  REFERRAL_BONUS         // Arkadasini getir bonusu
  LOYALTY_REWARD         // Sadakat odulu (12. ay vb.)
  CUSTOM                 // Admin tarafindan ozel tanimlanan
}

enum PromoStatus {
  ACTIVE
  USED
  EXPIRED
  CANCELLED
}

model PromoTemplate {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String      @db.VarChar(200)
  type             PromoType
  description      String?     @db.VarChar(500)
  discountPercent  Int         @map("discount_percent")          // 100 = tamamen ucretsiz, 50 = %50 indirim
  durationMonths   Int         @map("duration_months")           // Kac ay gecerli (orn. 3 = ilk 3 ay)
  isActive         Boolean     @default(true) @map("is_active")
  isAutoApply      Boolean     @default(false) @map("is_auto_apply")  // Yeni kayitlara otomatik uygula
  maxUsageCount    Int?        @map("max_usage_count")           // Toplam kullanim limiti (null = sinirsiz)
  currentUsage     Int         @default(0) @map("current_usage")
  validFrom        DateTime?   @map("valid_from") @db.Timestamptz()
  validUntil       DateTime?   @map("valid_until") @db.Timestamptz()
  createdAt        DateTime    @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime    @updatedAt @map("updated_at") @db.Timestamptz()
  userPromos       UserPromo[]

  @@index([type, isActive], map: "idx_promo_template_type")
  @@map("promo_templates")
}

model UserPromo {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String      @map("user_id") @db.Uuid
  templateId      String      @map("template_id") @db.Uuid
  contractId      String?     @map("contract_id") @db.Uuid
  status          PromoStatus @default(ACTIVE)
  remainingMonths Int         @map("remaining_months")           // Kalan ay sayisi
  activatedAt     DateTime    @default(now()) @map("activated_at") @db.Timestamptz()
  expiresAt       DateTime?   @map("expires_at") @db.Timestamptz()
  referredByUserId String?    @map("referred_by_user_id") @db.Uuid  // Referral icin: kim davet etti
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime    @updatedAt @map("updated_at") @db.Timestamptz()

  user            User        @relation("UserPromos", fields: [userId], references: [id])
  template        PromoTemplate @relation(fields: [templateId], references: [id])
  contract        Contract?   @relation(fields: [contractId], references: [id])
  referredByUser  User?       @relation("ReferredPromos", fields: [referredByUserId], references: [id])

  @@index([userId, status], map: "idx_user_promo_user_status")
  @@index([templateId], map: "idx_user_promo_template")
  @@map("user_promos")
}

// ─── Newsletter Subscribers ───

model NewsletterSubscriber {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique @db.VarChar(255)
  name          String?   @db.VarChar(200)
  isVerified    Boolean   @default(false) @map("is_verified")
  isActive      Boolean   @default(true) @map("is_active")
  source        String    @default("landing") @db.VarChar(50) // landing, register, dashboard
  unsubscribedAt DateTime? @map("unsubscribed_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([email], map: "idx_newsletter_email")
  @@index([isActive], map: "idx_newsletter_active")
  @@map("newsletter_subscribers")
}

// ─── Analytics ───

model AnalyticsEvent {
  id            String   @id @default(uuid()) @db.Uuid
  sessionId     String   @map("session_id") @db.VarChar(64)
  eventType     String   @map("event_type") @db.VarChar(30)   // page_view, page_exit, error, click
  page          String   @db.VarChar(500)                      // /dashboard, /fiyatlandirma, etc.
  referrer      String?  @db.VarChar(500)
  duration      Int?                                           // seconds on page (page_exit)
  userId        String?  @map("user_id") @db.Uuid
  ipAddress     String?  @map("ip_address") @db.VarChar(45)
  country       String?  @db.VarChar(5)                        // TR, US, etc.
  city          String?  @db.VarChar(100)
  userAgent     String?  @map("user_agent") @db.VarChar(500)
  device        String?  @db.VarChar(20)                       // desktop, mobile, tablet
  browser       String?  @db.VarChar(50)                       // Chrome, Safari, Firefox
  os            String?  @db.VarChar(50)                       // Windows, macOS, iOS, Android
  screenWidth   Int?     @map("screen_width")
  screenHeight  Int?     @map("screen_height")
  errorMessage  String?  @map("error_message") @db.VarChar(1000)
  errorStack    String?  @map("error_stack") @db.Text
  metadata      Json?                                          // extra event data
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([eventType, createdAt], map: "idx_analytics_type_date")
  @@index([page, createdAt], map: "idx_analytics_page_date")
  @@index([sessionId], map: "idx_analytics_session")
  @@index([userId], map: "idx_analytics_user")
  @@index([createdAt], map: "idx_analytics_created")
  @@map("analytics_events")
}
