{
  "expo": {
    "name": "Kira Güvence",
    "slug": "securelend-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "securelend",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#b5391a"
    },
    "ios": {
      "bundleIdentifier": "com.kiraguvence.app",
      "buildNumber": "1",
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification",
          "remote-notification"
        ],
        "NSCameraUsageDescription": "Profil fotoğrafınızı çekmek için kamera erişimi gereklidir.",
        "NSPhotoLibraryUsageDescription": "Profil fotoğrafınızı seçmek için galeri erişimi gereklidir.",
        "CFBundleDisplayName": "Kira Güvence",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.securelend.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#b5391a"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "Profil fotoğrafınızı seçmek için galeri erişimi gereklidir.",
          "cameraPermission": "Profil fotoğrafınızı çekmek için kamera erişimi gereklidir."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1e40af"
        }
      ],
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3fe49b13-8ef9-4045-9d8c-b63fd5be567a"
      }
    },
    "owner": "eray.karacaoglan"
  }
}
